<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.odoo_s3_file_upload</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="S3 File Upload" name="odoo_s3_file_upload" groups="base.group_system">
                    <block title="S3-Compatible Storage">
                        <setting string="Bucket Name" help="Name of the S3 or R2 bucket for task attachments.">
                            <field name="s3_bucket_name" placeholder="my-bucket"/>
                        </setting>
                        <setting string="Region" help="AWS region (e.g. us-east-1). Used for signing even with custom endpoints.">
                            <field name="s3_region"/>
                        </setting>
                        <setting string="Endpoint URL" help="Leave empty for AWS. Set for Cloudflare R2 or other S3-compatible storage.">
                            <field name="s3_endpoint_url" placeholder="https://&lt;account_id&gt;.r2.cloudflarestorage.com"/>
                        </setting>
                        <setting string="Key Prefix" help="Optional prefix for all object keys.">
                            <field name="s3_key_prefix" placeholder="production"/>
                        </setting>
                        <setting string="Presigned URL TTL" help="Lifetime of presigned upload/download URLs in seconds.">
                            <field name="s3_presigned_ttl_seconds"/>
                        </setting>
                        <setting string="Path-Style Addressing" help="Enable if your provider requires path-style S3 URLs.">
                            <field name="s3_use_path_style"/>
                        </setting>
                        <setting string="Blocked Extensions" help="Comma-separated extensions blocked on upload (e.g. .exe,.bat).">
                            <field name="s3_blocklist_extensions"/>
                        </setting>
                        <setting string="Credentials" help="Set S3_ACCESS_KEY_ID and S3_SECRET_ACCESS_KEY as container environment variables. They are never stored in the database.">
                            <div class="text-muted">
                                Credentials are read from environment variables only.
                            </div>
                            <button
                                name="action_test_s3_connection"
                                type="object"
                                string="Test Connection"
                                class="btn-primary mt-2"
                            />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
